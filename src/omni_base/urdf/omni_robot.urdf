<?xml version="1.0"?>
<robot name="omni_bot">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="-1.5708 0 1.5708"/>
      <geometry>
	<mesh filename="package://omni_base/meshes/entire_robot.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="laser"/>

  <joint name="base_laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.0 0.0 0.16" rpy="0.0 0.0 3.14159"/>
  </joint>

</robot>
